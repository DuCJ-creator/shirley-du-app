rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      // Required keys for creation
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() <= 256 &&
             (data.get('points', 0) is number) &&
             (data.get('streak', 0) is number) &&
             (data.get('avatarUrl', '') is string) &&
             (data.get('avatarUrl', '').size() <= 1000000); // 1MB limit for b64
    }

    function isValidPet(data) {
      return data.keys().hasAll(['ownerId', 'name', 'type', 'hunger', 'happiness', 'level']) &&
             data.ownerId == request.auth.uid &&
             data.name is string &&
             data.name.size() <= 64 &&
             data.type is string &&
             data.hunger is number &&
             data.happiness is number &&
             data.level is number;
    }

    function isValidLog(data) {
       return data.keys().hasAll(['type', 'points', 'description', 'timestamp']) &&
              data.type is string &&
              data.points is number &&
              data.description is string &&
              data.timestamp == request.time; // Mandatory server timestamp
    }

    function isValidNote(data) {
       return data.get('content', '') is string &&
              data.get('content', '').size() <= 65536 &&
              data.get('date', '') is string &&
              (data.get('drawingData', '') is string);
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if isOwner(userId); // Explicitly restricted to owner
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().uid == existing().uid &&
        incoming().email == existing().email &&
        incoming().diff(existing()).affectedKeys().hasOnly([
          'points', 'streak', 'lastCheckIn', 'lastActivity', 'studyTimeTotal', 
          'dailyWord', 'dailyQuote', 'dailyWordData', 'dailyQuoteData', 
          'avatarUrl', 'avatarType'
        ])
      );

      match /pets/{petId} {
        allow get: if isOwner(userId) && isValidId(petId);
        allow list: if isOwner(userId);
        
        allow create: if isOwner(userId) && isValidPet(incoming());
        
        allow update: if isOwner(userId) && isValidPet(incoming()) && (
          incoming().ownerId == existing().ownerId &&
          incoming().diff(existing()).affectedKeys().hasOnly([
            'hunger', 'happiness', 'level', 'xp', 'maxXp', 'lastFed', 'name', 'image', 'isPlaying'
          ])
        );
        
        allow delete: if isOwner(userId);
      }

      match /logs/{logId} {
        allow get: if isOwner(userId) && isValidId(logId);
        allow list: if isOwner(userId);
        
        allow create: if isOwner(userId) && isValidLog(incoming());
        
        allow update, delete: if false; // POINT LOGS ARE IMMUTABLE
      }

      match /notes/{noteId} {
        allow get: if isOwner(userId) && isValidId(noteId);
        allow list: if isOwner(userId);
        
        allow create: if isOwner(userId) && isValidNote(incoming());
        allow update: if isOwner(userId) && isValidNote(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
